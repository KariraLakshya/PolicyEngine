# ── LLM ──────────────────────────────────────────────────────────────────────
GROQ_API_KEY=gsk_YOUR_KEY_HERE
GROQ_MODEL=llama-3.3-70b-versatile

# ── MCP servers ───────────────────────────────────────────────────────────────
# Local: http://localhost:8001  |  Deployed: https://YOUR-MCP.up.railway.app
MCP_SERVER_URL=http://localhost:8001

# Remote MCP (optional second server).
# Context7 (free, no key): https://mcp.context7.com/mcp
# Exa (needs EXA_API_KEY):  https://mcp.exa.ai/mcp
REMOTE_MCP_URL=https://mcp.context7.com/mcp

# ── Agent behaviour ───────────────────────────────────────────────────────────
APPROVAL_TTL_SECONDS=1800

# ── Production only (set in Railway dashboard, not needed locally) ────────────
# PORT is injected automatically by Railway — do not set it here.
